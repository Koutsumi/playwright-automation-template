meta {
  name: Atualizar nota final do projeto
  type: http
  seq: 2
}

put {
  url: {{BASE_URL}}/evaluationGradingFinalScore
  body: json
  auth: inherit
}

body:json {
  {
      "_id": "{{evaluationGradingId}}",
      "newScoreFinal": {{finalScore}},
      "scoreFinalJustification": "Nota gerada automaticamente"
  }
}

script:pre-request {
  const score = Math.floor(Math.random() * 11);
  bru.setVar("finalScore", score);
}

settings {
  encodeUrl: true
  timeout: 0
}
