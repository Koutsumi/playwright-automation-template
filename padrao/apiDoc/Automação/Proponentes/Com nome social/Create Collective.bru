          },
          "naturalPersonCulturalProfileV2": {
              "type": "NaturalPerson",
              "demographics": {
                  "sex": "male",
                  "gender": "cisMan",
                  "genderDescription": null,
                  "ethnicity": "white",
                  "belongsToTraditionalCommunity": "native",
                  "belongsToTraditionalCommunityDescription": null,
                  "maritalStatus": "stableUnion",
                  "maritalStatusDescription": null,
                  "hasDisability": "no",
                  "disabilityType": null,
                  "disabilityTypeDescription": null,
                  "monthlyFamilyIncome": "1500To3000",
                  "educationLevel": "postgraduateLatoSensu",
                  "educationKnowledgeArea": "biologicalSciences",
