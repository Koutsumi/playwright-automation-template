vars:post-response {
  collectiveId: res.body.DATA._id
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Successfully created the proponent
}

settings {
  encodeUrl: true
  timeout: 0
}
