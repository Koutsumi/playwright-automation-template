meta {
  name: Create Collective
  type: http
  seq: 4
}

post {
  url: {{BASE_URL}}/proponent
  body: json
  auth: inherit
}

headers {
  Origin: {{BASE_URL}}
}

body:json {
  {
      "proponent": {
          "personType": "Collective",
          "identification": {
              "corporateName": "{{$randomCompanyName}}",
              "website": "",
