meta {
  name: unauthorized update
  type: http
  seq: 5
}

put {
  url: {{BASE_URL}}/notice-groups/6989fce8a100ea082072c848
  body: json
  auth: inherit
}

body:json {
  {
      "name": "Alterando o nome do grup",
      "description": "test",
      "restrictSubmissions": false
  }
}

assert {
  res.status: eq 403
  res.body.STATUS: eq DENIED
  res.body.MESSAGE: eq User is not authorized to access the requested resource
  res.body.DATA: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
