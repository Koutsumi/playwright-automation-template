meta {
  name: unauthorized
  type: http
  seq: 3
}

post {
  url: {{BASE_URL}}/notice-groups/
  body: json
  auth: none
}

body:json {
  {
      "name": null,
      "description": "test",
      "restrictSubmissions": false
  }
}

assert {
  res.status: eq 403
  res.body.STATUS: eq DENIED
  res.body.MESSAGE: eq User is not authorized to access the requested resource
  res.body.DATA: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
