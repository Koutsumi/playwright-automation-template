meta {
  name: Active links - Unathorized
  type: http
  seq: 2
}

get {
  url: {{BASE_URL}}/shareData?noticeId={{noticeId}}&type=PITCH
  body: none
  auth: inherit
}

params:query {
  noticeId: {{noticeId}}
  type: PITCH
}

vars:pre-request {
  noticeId: 695e3f920def3c082013cb91
}

assert {
  res.status: eq 403
  res.body.STATUS: eq DENIED
  res.body.MESSAGE: eq User is not authorized to access the requested resource
  res.body.DATA: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
