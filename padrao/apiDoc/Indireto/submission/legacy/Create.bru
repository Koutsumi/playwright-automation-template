meta {
  name: Create
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/submission/legacy
  body: json
  auth: inherit
}

body:json {
  {
      "noticeId": "62561852f50b9b001b416456"
  }
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Successfully create the legacy submission
}

script:post-response {
  const data = res.getBody()
  bru.setEnvVar("submissionLegacyId", data.DATA._id)
  
}

settings {
  encodeUrl: true
  timeout: 0
}
