meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/auth/login
  body: json
  auth: inherit
}

body:json {
  {
    "email": "{{user_email}}",
    "password": "{{user_password}}"
  }
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Success! You are logged in.
}

script:post-response {
  const data = res.getBody()
  bru.setEnvVar("userId", data.DATA._id)
  
}

settings {
  encodeUrl: true
  timeout: 0
}

example {
  name: 200 OK
  
  request: {
    url: {{BASE_URL}}/auth/login
    method: POST
    mode: json
