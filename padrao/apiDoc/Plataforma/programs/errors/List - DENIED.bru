meta {
  name: List - DENIED
  type: http
  seq: 1
}

get {
  url: {{BASE_URL}}/program
  body: none
  auth: inherit
}

assert {
  res.status: eq 401
  res.body.STATUS: eq DENIED
  res.body.MESSAGE: eq This resource cannot be access by anonnimous request
  res.body.DATA: isEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}
