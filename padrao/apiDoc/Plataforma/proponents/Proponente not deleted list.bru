meta {
  name: Proponente not deleted list
  type: http
  seq: 6
}

get {
  url: {{BASE_URL}}/userProponentsNotDeleted?userId={{userId}}
  body: none
  auth: inherit
}

params:query {
  userId: {{userId}}
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Proponents listed successfully
  res.body.DATA: isNotEmpty
  res.boy.DATA.proponents: isNotEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}

