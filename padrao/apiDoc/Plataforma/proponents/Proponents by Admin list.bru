meta {
  name: Proponents by Admin list
  type: http
  seq: 7
}

get {
  url: {{BASE_URL}}/proponentsByAdmin?page=2
  body: none
  auth: inherit
}

params:query {
  page: 2
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Proponents listed successfully
  res.body.DATA: isNotEmpty
  res.body.DATA.total: gt 0
  res.body.DATA.proponents: isNotEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}

