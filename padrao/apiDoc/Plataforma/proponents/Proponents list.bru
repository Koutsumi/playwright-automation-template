meta {
  name: Proponents list
  type: http
  seq: 5
}

get {
  url: {{BASE_URL}}/proponents?page=1
  body: none
  auth: bearer
}

params:query {
  page: 1
}

auth:bearer {
  token: {{tokekn}}
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Proponents listed successfully
  res.body.DATA: isNotEmpty
}

settings {
  encodeUrl: true
  timeout: 0
}

