        }
      }
    }
  }
}

assert {
  res.status: eq 200
  res.body.STATUS: eq SUCCESS
  res.body.MESSAGE: eq Successfully created the proponent
}

script:post-response {
  const data = res.getBody()
  bru.setEnvVar("naturalPersonId", data.DATA._id)
  
  console.log(data.DATA._id)
  
}

settings {
  encodeUrl: true
  timeout: 0
}
