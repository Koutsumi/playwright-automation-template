        }
      }
    }
  }
}

assert {
  res.status: eq 400
  res.body.STATUS: eq FAILURE
}

script:post-response {
  if(res.status === 200){
    const data = res.getBody()
    bru.setEnvVar("naturalPersonId", data.DATA._id)
  
    console.log(data.DATA._id)
  }
  
  
}

settings {
  encodeUrl: true
  timeout: 0
}

