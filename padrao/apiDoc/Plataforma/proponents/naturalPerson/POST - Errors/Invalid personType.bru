      },
      "naturalPersonCulturalProfile": null,
      "naturalPersonCulturalProfileV2": {
        "type": "NaturalPerson",
        "demographics": {
          "sex": "female",
          "gender": "cisWoman",
          "ethnicity": "white",
          "belongsToTraditionalCommunity": "no",
          "maritalStatus": "stableUnion",
          "hasDisability": "no",
          "monthlyFamilyIncome": "upTo1500",
          "educationLevel": "undergraduateComplete",
          "educationKnowledgeArea": "exactAndEarthSciences",
          "academicSegment": "Repellendus asperiores veritatis sapiente."
        },
        "experienceAndCulturalParticipation": {
