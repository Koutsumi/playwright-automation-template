          ],
          "mainAreaOfCulturalActivitySegment": "performingArts",
          "mainAreaOfCulturalActivitySegmentOptions": [
            "theater"
          ],
          "otherCulturalFields": [
            "cinemaRadioTv",
            "visualArts"
          ],
          "mainArtisticCulturalOccupation": "acrobata"
