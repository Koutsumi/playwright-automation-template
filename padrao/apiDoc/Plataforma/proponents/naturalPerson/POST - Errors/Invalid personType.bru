meta {
  name: Invalid personType
  type: http
  seq: 1
}

post {
  url: {{BASE_URL}}/proponent
  body: json
  auth: inherit
}

headers {
  Origin: {{BASE_URL}}
}

body:json {
  {
    "proponent": {
      "personType": "InvalidPersonType",
      "identification": {
        "name": "Laís Duarte Social Name",
